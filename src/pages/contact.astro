---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, waLink } from '../data/site';
---

<BaseLayout title="Contact" description="Get in touch with VIANY.DIXON via WhatsApp, email or our contact form.">
  <section class="px-5 sm:px-8 py-16 lg:py-24">
    <div class="max-w-[1100px] mx-auto grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
      <div class="lg:col-span-2">
        <p class="text-[11px] tracking-[0.18em] uppercase font-bold mb-3 text-(--color-muted)">Get In Touch</p>
        <h1 class="text-4xl sm:text-5xl font-medium tracking-[-0.025em] leading-[1.05] mb-6">Talk to us.</h1>
        <p class="text-(--color-muted) mb-8">
          Questions about a product, an order, a collaboration? We respond within 24 hours.
        </p>

        <div class="space-y-5">
          <a href={waLink()} target="_blank" rel="noopener" class="flex items-center gap-4 p-4 border border-(--color-line) hover:border-(--color-ink) transition-colors group">
            <span class="w-10 h-10 rounded-full bg-[#25D366] text-white flex items-center justify-center text-xl">📱</span>
            <div>
              <p class="text-[10px] tracking-[0.15em] uppercase font-bold text-(--color-muted)">WhatsApp</p>
              <p class="text-sm font-semibold">{SITE.whatsapp.displayName}</p>
            </div>
          </a>

          <a href={`mailto:${SITE.email}`} class="flex items-center gap-4 p-4 border border-(--color-line) hover:border-(--color-ink) transition-colors">
            <span class="w-10 h-10 rounded-full bg-(--color-ink) text-white flex items-center justify-center text-xl">✉️</span>
            <div>
              <p class="text-[10px] tracking-[0.15em] uppercase font-bold text-(--color-muted)">Email</p>
              <p class="text-sm font-semibold">{SITE.email}</p>
            </div>
          </a>

          <a href={SITE.instagramUrl} target="_blank" rel="noopener" class="flex items-center gap-4 p-4 border border-(--color-line) hover:border-(--color-ink) transition-colors">
            <span class="w-10 h-10 rounded-full bg-gradient-to-br from-purple-500 via-pink-500 to-yellow-400 text-white flex items-center justify-center text-xl">📷</span>
            <div>
              <p class="text-[10px] tracking-[0.15em] uppercase font-bold text-(--color-muted)">Instagram</p>
              <p class="text-sm font-semibold">@{SITE.instagram}</p>
            </div>
          </a>
        </div>
      </div>

      <div class="lg:col-span-3">
        <form action="https://formspree.io/f/REPLACE-WITH-FORMSPREE-ID" method="POST" class="space-y-5 bg-(--color-cream) p-8 lg:p-10">
          <div>
            <label class="block text-[11px] tracking-[0.12em] uppercase font-bold mb-2" for="name">Name</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-3 border border-(--color-line) bg-white text-sm focus:border-(--color-ink) outline-none transition-colors" />
          </div>

          <div>
            <label class="block text-[11px] tracking-[0.12em] uppercase font-bold mb-2" for="email">Email</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-(--color-line) bg-white text-sm focus:border-(--color-ink) outline-none transition-colors" />
          </div>

          <div>
            <label class="block text-[11px] tracking-[0.12em] uppercase font-bold mb-2" for="subject">Subject</label>
            <select id="subject" name="subject" class="w-full px-4 py-3 border border-(--color-line) bg-white text-sm focus:border-(--color-ink) outline-none transition-colors">
              <option>General question</option>
              <option>Wholesale inquiry</option>
              <option>Product / sizing</option>
              <option>Collaboration / press</option>
              <option>Other</option>
            </select>
          </div>

          <div>
            <label class="block text-[11px] tracking-[0.12em] uppercase font-bold mb-2" for="message">Message</label>
            <textarea id="message" name="message" rows="6" required class="w-full px-4 py-3 border border-(--color-line) bg-white text-sm focus:border-(--color-ink) outline-none transition-colors resize-y"></textarea>
          </div>

          <button type="submit" class="btn btn-primary w-full sm:w-auto">Send Message</button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
