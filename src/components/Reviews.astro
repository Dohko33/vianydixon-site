---
// Reviews — sand-alt band, big 4.9 + stars header, 4 review cards
// (design spec §9). Grid on desktop, horizontal snap-scroll on mobile.
const reviews = [
  { quote: "Best swimwear I've ever owned. The fabric is technical but feels luxurious — I wore it snorkeling at sunrise and out to dinner the same day.",
    name: 'Emma S.', location: 'Roatán, Honduras' },
  { quote: 'I bought the navy trucker for my husband and ended up wearing it every day myself. The fit is perfect and the quality is unreal.',
    name: 'Lucia M.', location: 'Tegucigalpa, Honduras' },
  { quote: 'The crystal slip-ons turn every outfit into an event. Got compliments from total strangers on the boat. Worth every penny.',
    name: 'Daniela R.', location: 'Miami, USA' },
  { quote: "Finally a brand that designs for Caribbean life. Sun protection that doesn't feel like a wetsuit.",
    name: 'Marcus T.', location: 'Bay Islands, Honduras' },
];
const star = 'M12 2l2.9 6.3 6.9.7-5.1 4.6 1.4 6.8L12 17.8 5.9 20.4l1.4-6.8L2.2 9l6.9-.7L12 2Z';
---

<section class="vd-section" style="background:#F1E9DA">
  <div class="vd-container">
    <div class="head">
      <div>
        <div class="vd-eyebrow" style="margin-bottom:16px">Customer Stories</div>
        <h2 class="vd-h2">Why Our People Love It</h2>
      </div>
      <div class="score">
        <span class="num">4.9</span>
        <div>
          <div class="stars">
            {[1,2,3,4,5].map(() => (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d={star}/></svg>
            ))}
          </div>
          <div class="based">Based on 312 verified reviews</div>
        </div>
      </div>
    </div>

    <div class="grid">
      {reviews.map((r) => (
        <article class="card">
          <div class="stars small">
            {[1,2,3,4,5].map(() => (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d={star}/></svg>
            ))}
          </div>
          <p>"{r.quote}"</p>
          <div class="who">
            <div class="name">{r.name}</div>
            <div class="meta">{r.location} · Verified buyer</div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .head {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 24px; flex-wrap: wrap; margin-bottom: 44px;
  }
  .score { display: flex; align-items: center; gap: 14px; }
  .num { font: 400 40px/1 var(--font-serif); color: #0F2C36; }
  .stars { display: flex; gap: 2px; color: #E7A33E; }
  .based { margin-top: 5px; font: 400 12.5px/1 var(--font-sans); color: #8a8575; }

  .grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; align-items: stretch; }
  .card { background: #fff; border: 1px solid #EBE3D2; border-radius: 16px; padding: 26px; display: flex; flex-direction: column; }
  .card .stars { margin-bottom: 16px; }
  .card p { margin: 0; font: 400 16px/1.55 var(--font-serif); font-style: italic; color: #2c3d43; }
  .who { margin-top: auto; padding-top: 18px; border-top: 1px solid #EFE7D6; }
  .name { font: 600 14px/1.2 var(--font-sans); color: #0F2C36; }
  .meta { margin-top: 3px; font: 400 12px/1.3 var(--font-sans); color: #8a8575; }

  @media (max-width: 1023px) { .grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 639px) {
    .grid {
      display: flex; gap: 14px; overflow-x: auto;
      scroll-snap-type: x mandatory; scrollbar-width: none;
      margin: 0 calc(-1 * clamp(20px, 4vw, 48px));
      padding: 0 clamp(20px, 4vw, 48px) 6px;
    }
    .grid::-webkit-scrollbar { display: none; }
    .card { flex: 0 0 85%; scroll-snap-align: start; }
  }
</style>
