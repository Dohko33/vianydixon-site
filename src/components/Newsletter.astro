---
// Newsletter signup — captures emails for early-access drops
---

<section class="bg-(--color-ink) text-white px-5 sm:px-8 py-14 lg:py-20">
  <div class="max-w-[900px] mx-auto text-center">
    <h2 class="font-serif italic text-3xl sm:text-4xl lg:text-5xl font-normal tracking-[-0.015em] leading-[1.05] mb-4">Join the Community</h2>
    <p class="text-white/80 text-base sm:text-lg mb-8 max-w-xl mx-auto">
      Early access to drops, events and 10% off your first order.
    </p>

    <form action="https://formspree.io/f/REPLACE-WITH-FORMSPREE-ID" method="POST" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <input type="email" name="email" placeholder="your@email.com" required
             class="flex-1 px-5 py-3 text-(--color-ink) bg-white text-sm outline-none focus:ring-2 focus:ring-white/50" />
      <button type="submit" class="btn" style="background:white;color:#000;">Subscribe</button>
    </form>
  </div>
</section>
