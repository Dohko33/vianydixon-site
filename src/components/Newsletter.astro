---
// Newsletter — teal gradient band, glass pill form (design spec §11).
---

<section class="vd-news">
  <div class="glow" aria-hidden="true"></div>
  <div class="inner">
    <h2>Join the Community</h2>
    <p>Early access to drops, events and 10% off your first order.</p>
    <form action="https://formspree.io/f/REPLACE-WITH-FORMSPREE-ID" method="POST" class="pill">
      <input type="email" name="email" placeholder="you@email.com" required />
      <button type="submit" class="btn btn-primary" style="padding:14px 28px">Subscribe</button>
    </form>
  </div>
</section>

<style>
  .vd-news {
    position: relative; overflow: hidden;
    background: linear-gradient(115deg, #0B242D 0%, #12505C 58%, #12909B 120%);
    padding: clamp(64px, 8vw, 104px) 0;
  }
  .glow {
    position: absolute; top: -140px; left: -60px; width: 400px; height: 400px;
    border-radius: 50%; background: radial-gradient(circle, rgba(127,203,211,.3), transparent 70%);
    pointer-events: none;
  }
  .inner {
    position: relative; max-width: 720px; margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px); text-align: center;
  }
  h2 {
    margin: 0; font: 400 clamp(34px, 4.4vw, 54px)/1.05 var(--font-serif);
    letter-spacing: -.015em; color: #fff;
  }
  p { margin: 16px 0 0; font: 400 17px/1.6 var(--font-sans); color: rgba(207,237,239,.82); }

  .pill {
    margin: 34px auto 0; max-width: 520px;
    display: flex; gap: 10px;
    background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.25);
    border-radius: 100px; padding: 7px 7px 7px 22px; backdrop-filter: blur(8px);
  }
  .pill input {
    flex: 1; min-width: 0; background: none; border: 0; outline: none;
    color: #fff; font: 400 15px/1 var(--font-sans);
  }
  .pill input::placeholder { color: rgba(255,255,255,.55); }
  .pill button { flex-shrink: 0; }

  @media (max-width: 479px) {
    .pill { flex-direction: column; border-radius: 24px; padding: 10px; gap: 8px; }
    .pill input { padding: 10px 12px; text-align: center; }
  }
</style>
