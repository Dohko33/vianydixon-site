---
// Brand Story — sand-alt band, image flush left, editorial text right with
// founder signature (design spec §6).
---

<section class="vd-story">
  <div class="wrap">
    <div class="media">
      <img src="/images/brand-story.jpg" alt="Viany Dixon · Founder" loading="lazy" />
    </div>
    <div class="text">
      <div class="vd-eyebrow" style="margin-bottom:20px">Our Story</div>
      <h2>From the islands,<br/>for the world.</h2>
      <p>Founded in Roatán by Viany Dixon. Performance wear built for the sea, the sun, and the way we live in the islands. Every piece is designed with the Caribbean in mind — and crafted to travel anywhere.</p>
      <div class="sig">
        <div class="rule"></div>
        <div>
          <div class="name">Viany Dixon</div>
          <div class="role">Founder</div>
        </div>
      </div>
      <a href="/about" class="btn btn-dark" style="align-self:flex-start;margin-top:34px">
        Read Our Story
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .vd-story { background: #F1E9DA; }
  .wrap {
    max-width: 1440px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr; align-items: stretch; min-height: 560px;
  }
  .media { position: relative; overflow: hidden; min-height: 420px; }
  .media img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }

  .text {
    display: flex; flex-direction: column; justify-content: center;
    padding: clamp(48px, 6vw, 84px) clamp(28px, 5vw, 80px);
  }
  h2 {
    margin: 0; font: 400 clamp(32px, 3.6vw, 50px)/1.06 var(--font-serif);
    letter-spacing: -.015em; color: #0F2C36;
  }
  p { margin: 26px 0 0; max-width: 460px; font: 400 17px/1.65 var(--font-sans); color: #54636A; }

  .sig { margin-top: 30px; display: flex; align-items: center; gap: 14px; }
  .rule { width: 44px; height: 1px; background: #0F2C36; opacity: .3; }
  .name { font: 500 17px/1.1 var(--font-serif); color: #0F2C36; }
  .role { margin-top: 3px; font: 500 12px/1 var(--font-sans); letter-spacing: .06em; text-transform: uppercase; color: #8a8575; }

  @media (max-width: 899px) {
    .wrap { grid-template-columns: 1fr; }
    .media { min-height: 320px; aspect-ratio: 4/3; }
  }
</style>
