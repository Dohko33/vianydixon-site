---
import { waLink } from '../data/site';
---

<section class="bg-white px-5 sm:px-8 py-12 lg:py-20 overflow-hidden">
  <div class="max-w-[1400px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-14 items-center">
    <div class="lg:col-span-7 order-2 lg:order-1">
      <div class="aspect-[4/3] sm:aspect-[5/4] overflow-hidden relative bg-(--color-sand)">
        <img src="/images/hero-feel-as-you-want.png" alt="Viany Dixon · Founder" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
      </div>
    </div>

    <div class="lg:col-span-5 order-1 lg:order-2 lg:pl-4">
      <p class="text-[11px] tracking-[0.18em] uppercase font-bold mb-4 text-(--color-muted)">Our Story</p>
      <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-medium tracking-[-0.025em] leading-[1.05] mb-6 text-(--color-ink)">
        From the islands,<br/>for the world.
      </h2>
      <div class="text-[15px] sm:text-base text-[#444] leading-relaxed space-y-4 mb-7 max-w-md">
        <p>Founded in Roatán by Viany Dixon. Performance wear built for the sea, the sun, and the way we live in the islands. Every piece is designed with the Caribbean in mind — and crafted to travel anywhere.</p>
      </div>
      <p class="font-medium text-(--color-ink) mb-7 italic text-lg">
        — Viany Dixon
        <span class="block not-italic text-[12px] tracking-[0.15em] uppercase font-bold text-(--color-muted) mt-1">Founder &amp; Designer</span>
      </p>
      <a href="/about" class="inline-flex items-center text-[12px] font-bold tracking-[0.12em] uppercase border-b-2 border-(--color-ink) pb-1 hover:opacity-70 transition-opacity">
        Read Our Story
        <span class="ml-2">→</span>
      </a>
    </div>
  </div>
</section>
