---
// Announcement bar — dark strip, 3 messages with bullet separators (design spec §1).
// On mobile only the first message shows.
const messages = [
  '🌎 Now shipping worldwide from Roatán',
  '🏝️ Find us at Roatan Thing · Kimpton Grand Roatán',
  '☀️ UPF 50+ certified swim & rashguards',
];
---

<div class="vd-announce">
  {messages.map((m, i) => (
    <>
      {i > 0 && <span class="sep" aria-hidden="true">•</span>}
      <span class={`msg ${i > 0 ? 'extra' : ''}`}>{m}</span>
    </>
  ))}
</div>

<style>
  .vd-announce {
    background: #0F2C36; color: #CFEDEF;
    font-size: 12.5px; letter-spacing: .04em; text-align: center;
    padding: 9px 16px;
  }
  .msg { opacity: .92; }
  .sep { opacity: .32; padding: 0 12px; }
  @media (max-width: 767px) {
    .extra, .sep { display: none; }
  }
</style>
