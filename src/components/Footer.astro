---
// Footer — darkest band, 4 columns + payment chips (design spec §12).
import { SITE, waLink } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="vd-footer">
  <div class="vd-container">
    <div class="cols">
      <div class="brand">
        <img src="/images/logo-stacked.png" alt={SITE.brandName} width="200" height="86" loading="lazy" />
        <p>Island performance wear. Designed in the Caribbean, made for the way we live in the islands.</p>
        <a href={SITE.instagramUrl} target="_blank" rel="noopener" class="ig">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          @{SITE.instagram}
        </a>
      </div>

      <div>
        <div class="h">Collections</div>
        <div class="links">
          <a href="/#collections">Swim</a>
          <a href="/#collections">Apparel</a>
          <a href="/#collections">Caps</a>
          <a href="/#collections">Footwear</a>
          <a href="/#collections">Accessories</a>
        </div>
      </div>

      <div>
        <div class="h">Find Us</div>
        <div class="links">
          <a href="/find-us">Retail</a>
          <a href="/wholesale">Wholesale</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
        </div>
      </div>

      <div>
        <div class="h">Get In Touch</div>
        <div class="links">
          <a href={waLink()} target="_blank" rel="noopener">WhatsApp · {SITE.whatsapp.displayName}</a>
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
          <a href={SITE.instagramUrl} target="_blank" rel="noopener">@{SITE.instagram}</a>
        </div>
      </div>
    </div>

    <div class="bottom">
      <div class="copy">© {year} {SITE.brandFull} · MD United Group LLC · Made with love in the Caribbean 🐟</div>
      <div class="chips">
        <span>VISA</span><span>MASTERCARD</span><span>AMEX</span><span>PAYPAL</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .vd-footer { background: #0A2029; color: #fff; padding: clamp(56px, 7vw, 84px) 0 32px; }

  .cols {
    display: grid; grid-template-columns: 1.6fr 1fr 1fr 1.2fr; gap: 40px;
    padding-bottom: 48px; border-bottom: 1px solid rgba(255,255,255,.1);
  }
  .brand img { height: 56px; width: auto; opacity: .95; }
  .brand p { margin: 20px 0 0; max-width: 280px; font: 400 14.5px/1.6 var(--font-sans); color: rgba(207,237,239,.6); }
  .ig {
    margin-top: 22px; display: inline-flex; align-items: center; gap: 9px;
    color: #fff; text-decoration: none; font: 500 13.5px/1 var(--font-sans);
    opacity: .85; transition: opacity .2s;
  }
  .ig:hover { opacity: .6; }

  .h { font: 600 12px/1 var(--font-sans); letter-spacing: .14em; text-transform: uppercase; color: #7FCBD3; margin-bottom: 18px; }
  .links { display: flex; flex-direction: column; gap: 12px; }
  .links a { color: rgba(255,255,255,.78); text-decoration: none; font: 400 14.5px/1.4 var(--font-sans); transition: color .2s; }
  .links a:hover { color: #fff; }

  .bottom {
    display: flex; align-items: center; justify-content: space-between;
    gap: 20px; flex-wrap: wrap; padding-top: 26px;
  }
  .copy { font: 400 12.5px/1.5 var(--font-sans); color: rgba(207,237,239,.5); }
  .chips { display: flex; gap: 8px; flex-wrap: wrap; }
  .chips span {
    padding: 5px 9px; border: 1px solid rgba(255,255,255,.16); border-radius: 5px;
    font: 600 10px/1 var(--font-sans); letter-spacing: .08em; color: rgba(255,255,255,.65);
  }

  @media (max-width: 899px) { .cols { grid-template-columns: 1fr 1fr; gap: 32px; } }
  @media (max-width: 539px) {
    .vd-footer { padding-top: 44px; }
    .cols { gap: 26px 18px; padding-bottom: 32px; }
    .brand { grid-column: span 2; }
    .brand img { height: 44px; }
    .links { gap: 9px; }
    .links a { font-size: 13px; }
  }
</style>
