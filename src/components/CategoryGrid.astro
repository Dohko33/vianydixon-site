---
// Categories — 3-col grid of 6 image cards, bottom gradient + name/desc (design spec §3).
const cats = [
  { label: 'Swim',        desc: 'Bikinis, one-pieces & boardshorts', href: '/collections/swim',        img: '/images/cat-swim.webp' },
  { label: 'Rashguard',   desc: 'UPF 50+ sun protection',            href: '/collections/apparel',     img: '/images/cat-apparel.webp' },
  { label: 'Caps',        desc: 'Structured trucker & dad caps',     href: '/collections/caps',        img: '/images/cat-caps.webp' },
  { label: 'Footwear',    desc: 'Slip-ons & sandals',                href: '/collections/shoes',       img: '/images/cat-footwear.webp' },
  { label: 'Sportswear',  desc: 'Move on land & sea',                href: '/collections/sportswear',  img: '/images/cat-sportswear.webp' },
  { label: 'Accessories', desc: 'Tumblers, totes & more',            href: '/collections/accessories', img: '/images/cat-accessories.webp' },
];
---

<section class="vd-section" style="background:#FBF7EF">
  <div class="vd-container">
    <div class="head">
      <div>
        <div class="vd-eyebrow" style="margin-bottom:16px">Our Collections</div>
        <h2 class="vd-h2">From Roatán to the World</h2>
      </div>
      <a href="/collections/swim" class="vd-link">View all
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>

    <div class="grid">
      {cats.map((c) => (
        <a href={c.href} class="card">
          <img src={c.img} alt={c.label} loading="lazy" />
          <div class="shade" aria-hidden="true"></div>
          <div class="label">
            <div class="name">{c.label}</div>
            <div class="desc">{c.desc}</div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .head {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 24px; flex-wrap: wrap; margin-bottom: 44px;
  }
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .card {
    position: relative; overflow: hidden; border-radius: 16px;
    aspect-ratio: 3/3.7; text-decoration: none; display: block;
  }
  .card img {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
    transition: transform .7s ease;
  }
  .card:hover img { transform: scale(1.06); }
  .shade { position: absolute; inset: 0; background: linear-gradient(to top, rgba(6,24,30,.78), transparent 58%); pointer-events: none; }
  .label { position: absolute; left: 0; right: 0; bottom: 0; padding: 22px; pointer-events: none; }
  .name { font: 500 24px/1 var(--font-serif); color: #fff; }
  .desc { margin-top: 6px; font: 500 12.5px/1 var(--font-sans); letter-spacing: .02em; color: rgba(255,255,255,.78); }

  @media (max-width: 899px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 539px) { .grid { grid-template-columns: 1fr 1fr; gap: 10px; } .label { padding: 14px; } .name { font-size: 19px; } .desc { font-size: 11px; } }
</style>
