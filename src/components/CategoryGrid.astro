---
// Categories — exact 1:1 of Shopify live (images, order, sizing)
const cats = [
  { label: 'Swim',        href: '/collections/swim',        bg: '#d9c9b5', img: '/images/cat-swim.png',        fit: 'cover' },
  { label: 'Rashguard',   href: '/collections/apparel',     bg: '#9bb5c7', img: '/images/cat-apparel.png',     fit: 'cover' },
  { label: 'Caps',        href: '/collections/caps',        bg: '#e8dbc4', img: '/images/cat-caps.png',        fit: 'cover' },
  { label: 'Footwear',    href: '/collections/shoes',       bg: '#c9cdd4', img: '/images/cat-footwear.png',    fit: 'cover' },
  { label: 'Sportswear',  href: '/collections/sportswear',  bg: '#d4b5ac', img: '/images/cat-sportswear.jpg',  fit: 'cover' },
  { label: 'Accessories', href: '/collections/accessories', bg: '#b8c5b5', img: '/images/cat-accessories.png', fit: 'cover' },
];
---

<section class="py-6 lg:py-10 bg-white">
  <div class="max-w-[1500px] mx-auto">
    <h2 class="text-[28px] sm:text-4xl lg:text-[48px] font-medium tracking-[-0.025em] leading-[1.05] mb-5 lg:mb-7 px-5 sm:px-8">
      From Roatán to the World
    </h2>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-3 gap-0">
      {cats.map((c) => (
        <a href={c.href} class="block group">
          <div class="aspect-square overflow-hidden relative" style={`background-color:${c.bg}`}>
            <img src={c.img} alt={c.label} loading="lazy"
                 class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
          </div>
          <p class="text-center text-[15px] sm:text-[17px] mt-3 mb-3">{c.label}</p>
        </a>
      ))}
    </div>
  </div>
</section>
