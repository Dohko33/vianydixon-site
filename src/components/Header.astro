---
// Header — white-on-dark. `overlay` = transparent, absolutely positioned over the hero
// (home). Default = solid deep-sea bar (sub-pages).
import { SITE, waLink } from '../data/site';
interface Props { overlay?: boolean }
const { overlay = false } = Astro.props;
---

<header class={`vd-header ${overlay ? 'overlay' : 'solid'}`}>
  <a href="/" aria-label={SITE.brandName} class="logo">
    <img src="/images/logo-stacked.png" alt={SITE.brandName} width="200" height="86" />
  </a>

  <nav class="nav">
    {SITE.nav.map((item) => (
      <a href={item.href}>{item.label}</a>
    ))}
  </nav>

  <div class="icons">
    <a href={waLink()} target="_blank" rel="noopener" aria-label="WhatsApp">
      <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4l-2.3-1c-.2-.1-.4 0-.5.1l-1 1.3c-1.4-.7-2.6-1.9-3.3-3.3l1.3-1c.1-.1.2-.3.1-.5l-1-2.3c-.1-.3-.4-.4-.7-.3-.7.2-1.3.7-1.7 1.3-.4.6-.6 1.4-.4 2.1.5 2.8 2.7 5 5.5 5.5.7.2 1.5 0 2.1-.4.6-.4 1.1-1 1.3-1.7.1-.3 0-.6-.3-.7zM12 2C6.5 2 2 6.5 2 12c0 1.7.4 3.3 1.2 4.7L2 22l5.4-1.2c1.3.7 2.9 1.1 4.5 1.1 5.5 0 10-4.5 10-10S17.5 2 12 2zm0 18c-1.5 0-3-.4-4.2-1.2L4 19.5l.7-3.6C3.9 14.7 3.5 13.4 3.5 12c0-4.7 3.8-8.5 8.5-8.5s8.5 3.8 8.5 8.5-3.8 8.5-8.5 8.5z"/></svg>
    </a>
    <a href="/contact" aria-label="Contact">
      <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-7 8-7s8 2.6 8 7"/></svg>
    </a>
    <a href="/wholesale" aria-label="Wholesale">
      <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8h12l-1 12H7L6 8Z"/><path d="M9 8V6.5a3 3 0 0 1 6 0V8"/></svg>
    </a>
  </div>
</header>

<style>
  .vd-header {
    display: flex; align-items: center; justify-content: space-between; gap: 24px;
    padding: 18px clamp(20px, 4vw, 48px);
    color: #fff;
  }
  .overlay { position: absolute; top: 0; left: 0; right: 0; z-index: 20; background: transparent; }
  .solid { background: #0F2C36; }

  .logo { display: inline-flex; align-items: center; flex-shrink: 0; }
  .logo img { height: 46px; width: auto; opacity: .97; }

  .nav { display: flex; align-items: center; gap: 30px; }
  .nav a {
    color: #fff; text-decoration: none;
    font: 500 13px/1 var(--font-sans); letter-spacing: .04em;
    opacity: .9; transition: opacity .2s;
  }
  .nav a:hover { opacity: .6; }

  .icons { display: flex; align-items: center; gap: 18px; flex-shrink: 0; }
  .icons a { color: #fff; opacity: .92; display: inline-flex; transition: opacity .2s; }
  .icons a:hover { opacity: .6; }

  @media (max-width: 899px) {
    .nav { display: none; }
  }
  @media (max-width: 479px) {
    .logo img { height: 38px; }
  }
</style>
