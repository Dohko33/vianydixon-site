---
import { SITE } from '../data/site';
const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white border-b border-(--color-line)" data-header>
  <div class="max-w-[1500px] mx-auto flex items-center px-5 sm:px-8 py-3 gap-4">
    <!-- LEFT: Logo -->
    <div class="flex-1 flex justify-start shrink-0">
      <a href="/" aria-label={SITE.brandName} class="flex items-center">
        <img src="/images/logo-stacked-black.png" alt={SITE.brandName}
             class="h-9 sm:h-10 lg:h-11 w-auto"
             width="786" height="221" />
      </a>
    </div>

    <!-- CENTER: Nav -->
    <ul class="hidden md:flex flex-1 justify-center gap-6 lg:gap-7 list-none m-0 p-0">
      {SITE.nav.map((item) => (
        <li>
          <a href={item.href}
             class="text-[13px] font-bold uppercase tracking-[0.05em] whitespace-nowrap pb-1 border-b-2 border-transparent hover:border-current transition-colors"
             style={`color:${item.accent ? 'var(--color-accent)' : 'var(--color-ink)'}`}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- RIGHT: Search + icons -->
    <div class="flex-1 flex justify-end items-center gap-3 sm:gap-4 shrink-0">
      <!-- Search pill (Lululemon-style) — always visible on desktop -->
      <form action="/search" method="get" class="hidden lg:flex items-center bg-[#F4F4F4] rounded-full px-4 py-2 gap-2 w-[220px] focus-within:bg-[#EDEDED] transition-colors">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" class="shrink-0 opacity-70">
          <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
        </svg>
        <input type="text" name="q" placeholder="Search"
               class="bg-transparent outline-none text-[13px] flex-1 placeholder:text-[#666]"/>
      </form>

      <!-- Search icon for mobile -->
      <button type="button" aria-label="Search" class="lg:hidden p-1 hover:opacity-60 transition-opacity" data-search-toggle>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
          <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
        </svg>
      </button>

      <!-- Account / Contact -->
      <a href="/contact" aria-label="Contact" class="hidden sm:block p-1 hover:opacity-60 transition-opacity">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
          <circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6"/>
        </svg>
      </a>

      <!-- Wholesale "bag" -->
      <a href="/wholesale" aria-label="Wholesale" class="p-1 hover:opacity-60 transition-opacity">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
          <path d="M5 7h14l-1.5 11a2 2 0 0 1-2 1.7H8.5a2 2 0 0 1-2-1.7L5 7Z"/>
          <path d="M9 7V5a3 3 0 0 1 6 0v2"/>
        </svg>
      </a>
    </div>
  </div>
</header>
