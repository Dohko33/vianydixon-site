---
// Find Us — Roatán Airport pop-up (matches Shopify findus section)
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0">
    <img src="/images/findus-airport.png" alt="" class="w-full h-full object-cover" loading="lazy" />
    <div class="absolute inset-0 bg-black/55"></div>
  </div>

  <div class="relative max-w-[1300px] mx-auto px-5 sm:px-8 py-16 lg:py-24 text-white">
    <p class="text-[11px] tracking-[0.18em] uppercase font-bold mb-3 text-white/80">Find Us In Person</p>
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-medium tracking-[-0.025em] leading-[1.05] mb-5 max-w-2xl">
      Visit the pop-up at Roatán Airport.
    </h2>
    <p class="text-base sm:text-lg text-white/85 leading-relaxed mb-8 max-w-2xl">
      Island Outfitters by VIANY.DIXON® — high-quality island apparel and souvenirs right at the Juan Manuel Gálvez International Airport.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 lg:gap-8 max-w-3xl mb-10">
      <div>
        <p class="text-[10px] tracking-[0.18em] uppercase font-bold text-white/60 mb-2">Location</p>
        <p class="text-sm sm:text-base">RTB Airport · Gate D5–D6</p>
      </div>
      <div>
        <p class="text-[10px] tracking-[0.18em] uppercase font-bold text-white/60 mb-2">Hours</p>
        <p class="text-sm sm:text-base">7:00 AM — 7:00 PM Daily</p>
      </div>
      <div>
        <p class="text-[10px] tracking-[0.18em] uppercase font-bold text-white/60 mb-2">City</p>
        <p class="text-sm sm:text-base">Coxen Hole, Roatán · Honduras</p>
      </div>
    </div>

    <a href="/find-us" class="btn" style="background:white;color:#000;">Get Directions</a>
  </div>
</section>
