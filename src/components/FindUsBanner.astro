---
// Find Us — centered header + 2 location cards with photos (design spec §8).
const locations = [
  {
    name: 'Island Shop',
    at: 'at Kimpton Grand Roatán Resort + Spa',
    address: 'West Bay Beach, Bay Islands, Roatán, Honduras',
    img: '/images/loc-kimpton.jpg',
    mapsUrl: 'https://maps.google.com/?q=Kimpton+Grand+Roatan+Resort+Spa',
  },
];
---

<section class="vd-section" style="background:#FBF7EF">
  <div class="vd-container">
    <div class="head">
      <div class="vd-eyebrow" style="margin-bottom:18px">Find Us In Person</div>
      <h2 class="vd-h2">Visit our retailers across Roatán.</h2>
      <p>VIANY.DIXON® apparel and souvenirs available at our partner locations across the Bay Islands.</p>
    </div>

    <div class="grid">
      {locations.map((l) => (
        <div class="card">
          <img src={l.img} alt={l.name} loading="lazy" />
          <div class="body">
            <h3>{l.name}</h3>
            <div class="at">{l.at}</div>
            <div class="addr">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21.5s7-6.2 7-12a7 7 0 1 0-14 0c0 5.8 7 12 7 12Z"/><circle cx="12" cy="9.5" r="2.5"/></svg>
              {l.address}
            </div>
            <a href={l.mapsUrl} target="_blank" rel="noopener" class="vd-link" style="margin-top:22px;font-size:12.5px;letter-spacing:.08em;padding-bottom:6px">
              Get Directions
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .head { text-align: center; max-width: 640px; margin: 0 auto 48px; }
  .head p { margin: 18px 0 0; font: 400 16.5px/1.6 var(--font-sans); color: #54636A; }

  .grid { display: grid; grid-template-columns: minmax(0, 620px); justify-content: center; gap: 24px; }
  .card { background: #fff; border: 1px solid #EBE3D2; border-radius: 18px; overflow: hidden; }
  .card > img { width: 100%; height: 230px; object-fit: cover; display: block; }

  .body { padding: 26px 28px 30px; }
  h3 { margin: 0; font: 500 24px/1.1 var(--font-serif); color: #0F2C36; }
  .at { margin-top: 6px; font: 500 13.5px/1.3 var(--font-sans); color: #12909B; }
  .addr {
    display: flex; align-items: flex-start; gap: 9px; margin-top: 16px;
    font: 400 14.5px/1.5 var(--font-sans); color: #54636A;
  }
  .addr svg { flex-shrink: 0; margin-top: 2px; }

  @media (max-width: 767px) { .grid { grid-template-columns: 1fr; } }
</style>
