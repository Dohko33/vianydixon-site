---
// Featured Products — exact replica of Shopify with color swatches
const products = [
  {
    id: 'slipons',
    title: 'Crystal Slip-On',
    href: '/collections/shoes',
    hero: '/images/slipons-collection-studio.jpg',
    colors: [
      { name: 'Black',  hex: '#1a1a1a', img: '/images/slipon-crystal-black-studio.jpg' },
      { name: 'White',  hex: '#FFFFFF', img: '/images/slipon-crystal-white-studio.jpg' },
      { name: 'Pewter', hex: '#9B9180', img: '/images/slipon-crystal-pewter-studio.jpg' },
    ],
  },
  {
    id: 'caps',
    title: 'Fish Mark Trucker',
    href: '/collections/caps',
    hero: '/images/caps-collection-studio.jpg',
    colors: [
      { name: 'Navy',  hex: '#1B2A4E', img: '/images/cap-navy-product.png' },
      { name: 'White', hex: '#FFFFFF', img: '/images/cap-white-product.png' },
      { name: 'Sky',   hex: '#5BA7C2', img: '/images/cap-sky-product.png' },
      { name: 'Black', hex: '#1a1a1a', img: '/images/cap-black-product.png' },
    ],
  },
];
---

<section class="bg-[#F2F2F2] text-(--color-ink) px-5 sm:px-8 py-10 lg:py-14">
  <div class="max-w-[1400px] mx-auto">
    <div class="flex items-end justify-between flex-wrap gap-4 mb-8 lg:mb-10">
      <div>
        <p class="text-[11px] tracking-[0.12em] uppercase font-bold mb-3 text-(--color-ink)/70">Featured</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-medium tracking-[-0.025em] leading-[1.05] text-(--color-ink)">Featured Products</h2>
      </div>
      <a href="/contact" class="text-[12px] font-bold tracking-[0.08em] uppercase border-b-2 border-(--color-ink) pb-1 text-(--color-ink) hover:opacity-70">View All</a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 lg:gap-6">
      {products.map((p) => (
        <div class="group bg-white text-(--color-ink) p-4 sm:p-5 lg:p-6 rounded-sm" style="box-shadow: 0 2px 8px rgba(0,0,0,0.04);">
          <a href={p.href} class="block">
            <div class="aspect-[4/3] overflow-hidden relative" style="background: radial-gradient(ellipse 80% 70% at 50% 38%, #F2EFE8 0%, #E0D8CC 60%, #CFC6B7 100%);">
              <img id={`fps-${p.id}-main`} src={p.hero} alt={p.title}
                   class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300"
                   width="1200" height="900" loading="lazy" />
            </div>
          </a>

          <div class="pt-4">
            <h3 class="text-base sm:text-lg font-semibold tracking-[-0.01em] text-(--color-ink) mb-3">
              <a href={p.href} class="hover:opacity-70">{p.title}</a>
            </h3>

            <div class="flex items-center gap-2.5" data-fps-swatches={p.id}>
              {p.colors.map((c, i) => (
                <button type="button" aria-label={`View ${c.name}`} title={c.name}
                        data-fps-image={c.img}
                        data-fps-target={`fps-${p.id}-main`}
                        class="fps-dot w-6 h-6 sm:w-7 sm:h-7 rounded-full border border-[#D9D9D9] hover:border-(--color-ink) transition-all"
                        style={`background-color:${c.hex}`}
                        data-active={i === 0 ? 'true' : undefined}>
                  <span class="sr-only">{c.name}</span>
                </button>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <style>
    .fps-dot[data-active="true"] {
      border-color: var(--color-ink);
      box-shadow: 0 0 0 2px white inset, 0 0 0 2px var(--color-ink);
    }
    .fps-dot:focus-visible {
      outline: 2px solid var(--color-ink);
      outline-offset: 3px;
    }
  </style>

  <script is:inline>
    (function () {
      document.querySelectorAll('.fps-dot').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
          e.preventDefault();
          var img = btn.getAttribute('data-fps-image');
          var t = document.getElementById(btn.getAttribute('data-fps-target'));
          if (!t || !img) return;
          t.style.opacity = '0';
          setTimeout(function () { t.src = img; t.style.opacity = '1'; }, 150);
          var group = btn.closest('[data-fps-swatches]');
          if (group) {
            group.querySelectorAll('.fps-dot').forEach(function (b) { b.removeAttribute('data-active'); });
            btn.setAttribute('data-active', 'true');
          }
        });
      });
    })();
  </script>
</section>
