---
// Featured Products — each card is a horizontal, swipeable gallery of the
// product's color variations. Color dots double as pagination indicators.
const products = [
  {
    id: 'slipons',
    badge: 'Bestseller', badgeStyle: 'accent',
    category: 'Footwear',
    title: 'Crystal Slip-On',
    href: '/#collections',
    fit: 'cover',
    colors: [
      { name: 'White',  hex: '#f4f4f2', img: '/images/shoe-white-editorial.jpg' },
      { name: 'Black',  hex: '#1a1a1a', img: '/images/shoe-black-editorial.jpg' },
      { name: 'Pewter', hex: '#9a958c', img: '/images/shoe-pewter-editorial.jpg' },
    ],
  },
  {
    id: 'caps',
    badge: 'New', badgeStyle: 'dark',
    category: 'Caps',
    title: 'Fish Mark Trucker',
    href: '/#collections',
    fit: 'contain',
    colors: [
      { name: 'Navy',  hex: '#14304a', img: '/images/cap-navy-product.webp' },
      { name: 'White', hex: '#f4f4f2', img: '/images/cap-white-product.webp' },
      { name: 'Sky',   hex: '#7fb6d6', img: '/images/cap-sky-product.webp' },
      { name: 'Black', hex: '#1a1a1a', img: '/images/cap-black-product.webp' },
    ],
  },
];
---

<section id="featured" class="vd-section" style="background:#FBF7EF; scroll-margin-top:80px">
  <div class="vd-container">
    <div class="head">
      <div>
        <div class="vd-eyebrow" style="margin-bottom:16px">Featured</div>
        <h2 class="vd-h2">This season's favourites</h2>
      </div>
      <a href="/contact" class="vd-link">View all
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>

    <div class="grid">
      {products.map((p) => (
        <div class="card">
          {/* Swipeable variation gallery. The scroller sits inside a non-scrolling
              .media wrapper so badge / heart / arrows stay anchored (they must NOT
              be children of the scroll container, or they slide away with it). */}
          <div class="media">
            <div class="gallery" data-gallery={p.id}>
              {p.colors.map((c) => (
                <div class="slide">
                  <img src={c.img} alt={`${p.title} — ${c.name}`} loading="lazy"
                       class={(c.fit || p.fit) === 'cover' ? 'fit-cover' : 'fit-contain'} />
                </div>
              ))}
            </div>
            <span class={`badge ${p.badgeStyle}`}>{p.badge}</span>
            <span class="heart" aria-hidden="true">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#0F2C36" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20.5S3.5 14.5 3.5 8.8A4.3 4.3 0 0 1 12 6.9a4.3 4.3 0 0 1 8.5 1.9C20.5 14.5 12 20.5 12 20.5Z"/></svg>
            </span>
            <button type="button" class="nav prev" data-dir="-1" aria-label="Previous color" hidden>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
            </button>
            <button type="button" class="nav next" data-dir="1" aria-label="Next color">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
            </button>
          </div>

          <div class="body">
            <div class="cat">{p.category}</div>
            <h3>{p.title}</h3>
            <div class="row">
              <div class="swatches" data-dots={p.id}>
                {p.colors.map((c, i) => (
                  <button type="button" title={c.name} aria-label={`View ${c.name}`}
                          class="dot" style={`background:${c.hex}`}
                          data-index={i} data-active={i === 0 ? 'true' : undefined}></button>
                ))}
              </div>
              <span class="count">{p.colors.length} colors</span>
              <a href="/#collections" class="shop">View
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <script is:inline>
    (function () {
      document.querySelectorAll('[data-gallery]').forEach(function (gallery) {
        var id = gallery.getAttribute('data-gallery');
        var dotsWrap = document.querySelector('[data-dots="' + id + '"]');
        if (!dotsWrap) return;
        var dots = dotsWrap.querySelectorAll('.dot');
        var slides = gallery.querySelectorAll('.slide');
        var media = gallery.parentElement;                 // .media wrapper (non-scrolling)
        var prev = media.querySelector('.nav.prev');
        var next = media.querySelector('.nav.next');
        var last = slides.length - 1;

        function currentIndex() {
          var w = slides[0] ? slides[0].offsetWidth : 1;
          return Math.round(gallery.scrollLeft / w);
        }
        function goTo(i) {
          i = Math.max(0, Math.min(last, i));
          sync(i); // update dots + arrows immediately, don't wait for scroll to settle
          gallery.scrollTo({ left: i * slides[0].offsetWidth, behavior: 'smooth' });
        }
        function sync(i) {
          dots.forEach(function (d, k) {
            if (k === i) d.setAttribute('data-active', 'true');
            else d.removeAttribute('data-active');
          });
          if (prev) prev.hidden = i <= 0;
          if (next) next.hidden = i >= last;
        }
        // Click a dot → scroll to that variation
        dots.forEach(function (dot) {
          dot.addEventListener('click', function () {
            goTo(parseInt(dot.getAttribute('data-index'), 10));
          });
        });
        // Click an arrow → previous / next variation
        [prev, next].forEach(function (btn) {
          if (!btn) return;
          btn.addEventListener('click', function () {
            goTo(currentIndex() + parseInt(btn.getAttribute('data-dir'), 10));
          });
        });
        // Swipe/scroll → update active dot + arrows
        var t;
        gallery.addEventListener('scroll', function () {
          clearTimeout(t);
          t = setTimeout(function () { sync(currentIndex()); }, 60);
        }, { passive: true });
        // Keep state in sync if the browser restores a scroll position on load
        sync(currentIndex());
      });
    })();
  </script>
</section>

<style>
  .head {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 24px; flex-wrap: wrap; margin-bottom: 44px;
  }
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 26px; }

  .card {
    background: #fff; border: 1px solid #EBE3D2; border-radius: 18px; overflow: hidden;
    transition: transform .3s, box-shadow .3s;
  }
  .card:hover { transform: translateY(-4px); box-shadow: 0 24px 50px rgba(15,44,54,.1); }

  /* Non-scrolling wrapper — holds the scroller + anchored overlays */
  .media { position: relative; aspect-ratio: 4/3.4; background: #fff; }

  /* Horizontal swipeable gallery of variations */
  .gallery {
    position: absolute; inset: 0;
    display: flex; overflow-x: auto;
    scroll-snap-type: x mandatory; scrollbar-width: none; -ms-overflow-style: none;
    scroll-behavior: smooth;
  }
  .gallery::-webkit-scrollbar { display: none; }
  .slide { flex: 0 0 100%; scroll-snap-align: start; position: relative; }
  .slide img { width: 100%; height: 100%; }
  .slide img.fit-contain { object-fit: contain; padding: 14px; }
  .slide img.fit-cover { object-fit: cover; padding: 0; }

  .badge {
    position: absolute; top: 16px; left: 16px; z-index: 2; padding: 7px 13px;
    color: #fff; font: 600 10.5px/1 var(--font-sans); letter-spacing: .1em;
    text-transform: uppercase; border-radius: 100px;
  }
  .badge.accent { background: var(--color-accent); }
  .badge.dark { background: #0F2C36; }

  .heart {
    position: absolute; top: 14px; right: 16px; z-index: 2; width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    background: #fff; border-radius: 50%; box-shadow: 0 4px 12px rgba(0,0,0,.08);
  }

  /* Prev / next variation arrows — always visible, on every device */
  .nav {
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 40px; height: 40px; border-radius: 50%; border: 0; z-index: 3;
    display: flex; align-items: center; justify-content: center; cursor: pointer;
    color: #0F2C36; background: rgba(255,255,255,.92);
    box-shadow: 0 4px 14px rgba(15,44,54,.16);
    transition: background .2s, transform .15s;
  }
  .nav.prev { left: 14px; }
  .nav.next { right: 14px; }
  .nav:hover { background: #fff; }
  .nav:active { transform: translateY(-50%) scale(.9); }
  .nav[hidden] { display: none; }
  @media (max-width: 767px) { .nav { width: 36px; height: 36px; } }

  .body { padding: 24px 26px 28px; }
  .cat { font: 600 11px/1 var(--font-sans); letter-spacing: .14em; text-transform: uppercase; color: #12909B; }
  h3 { margin: 10px 0 0; font: 500 25px/1.1 var(--font-serif); color: #0F2C36; }

  .row { display: flex; align-items: center; gap: 14px; margin-top: 18px; }
  .swatches { display: flex; gap: 8px; }
  .dot {
    width: 20px; height: 20px; border-radius: 50%; border: 0; cursor: pointer; padding: 0;
    box-shadow: 0 0 0 1.5px #fff, 0 0 0 2.5px #d9d2c4;
    transition: box-shadow .2s;
  }
  .dot[data-active="true"] { box-shadow: 0 0 0 1.5px #fff, 0 0 0 2.5px var(--color-accent); }
  .count { font: 500 12.5px/1 var(--font-sans); color: #8a8575; }
  .shop {
    margin-left: auto; display: inline-flex; align-items: center; gap: 7px;
    font: 600 12px/1 var(--font-sans); letter-spacing: .06em; text-transform: uppercase;
    color: #0F2C36; text-decoration: none; transition: gap .25s;
  }
  .shop:hover { gap: 12px; }

  @media (max-width: 767px) { .grid { grid-template-columns: 1fr; } }
</style>
