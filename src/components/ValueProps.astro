---
// Trust bar — dark band, 4 columns with aqua line icons (design spec §4).
const items = [
  { icon: 'sun',   title: 'UPF 50+ Certified',   sub: 'Independently tested' },
  { icon: 'globe', title: 'Roatán to the World', sub: 'Honduras-based shipping' },
  { icon: 'leaf',  title: 'Conscious Materials', sub: 'Made with care' },
  { icon: 'pin',   title: 'Designed in Roatán',  sub: 'Made for island life' },
];
---

<section class="vd-trust">
  <div class="vd-container grid">
    {items.map((it, i) => (
      <div class={`item ${i < 3 ? 'divider' : ''}`}>
        {it.icon === 'sun' && (
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#7FCBD3" stroke-width="1.6" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2.5v2.4M12 19.1v2.4M2.5 12h2.4M19.1 12h2.4M5.2 5.2l1.7 1.7M17.1 17.1l1.7 1.7M18.8 5.2l-1.7 1.7M6.9 17.1l-1.7 1.7"/></svg>
        )}
        {it.icon === 'globe' && (
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#7FCBD3" stroke-width="1.6" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c3 3 3 15 0 18M12 3c-3 3-3 15 0 18"/></svg>
        )}
        {it.icon === 'leaf' && (
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#7FCBD3" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20C4 12 10 4.5 20 4c1 10-6.5 16-14 16H4Z"/><path d="M9 15c2.5-3 5.5-5 9-6.5"/></svg>
        )}
        {it.icon === 'pin' && (
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#7FCBD3" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21.5s7-6.2 7-12a7 7 0 1 0-14 0c0 5.8 7 12 7 12Z"/><circle cx="12" cy="9.5" r="2.5"/></svg>
        )}
        <div>
          <div class="title">{it.title}</div>
          <div class="sub">{it.sub}</div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .vd-trust { background: #0F2C36; padding: 52px 0; }
  .grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }
  .item { display: flex; align-items: center; gap: 16px; }
  .item svg { flex-shrink: 0; }
  .divider { padding-right: 22px; border-right: 1px solid rgba(255,255,255,.12); }
  .title { font: 600 14.5px/1.2 var(--font-sans); color: #fff; }
  .sub { margin-top: 4px; font: 400 12.5px/1.3 var(--font-sans); color: rgba(207,237,239,.6); }

  @media (max-width: 899px) {
    .grid { grid-template-columns: 1fr 1fr; gap: 26px 22px; }
    .item:nth-child(2) { border-right: 0; padding-right: 0; }
  }
  @media (max-width: 479px) {
    .vd-trust { padding: 36px 0; }
    .grid { gap: 20px 14px; }
    .divider { border-right: 0; padding-right: 0; }
    .title { font-size: 13px; }
    .sub { font-size: 11.5px; }
  }
</style>
