---
// FAQ — accordion, one open at a time, first open by default (design spec §10).
const faqs = [
  { q: 'How do I find my size?', a: 'Every product page shows our size chart with measurements in cm and inches. See our full size guide for detailed instructions.' },
  { q: 'Where do you ship?', a: 'Worldwide from Honduras. Standard delivery to the US arrives in 5–8 business days. Inquire via WhatsApp for international rates.' },
  { q: 'Is your swimwear UPF certified?', a: 'Yes — all our swim and rashguard products are independently tested and certified UPF 50+.' },
  { q: 'Can I return or exchange?', a: 'Free returns within 30 days for unworn items with tags attached.' },
  { q: 'Do you have a physical store?', a: 'Yes — visit our Island Outfitters pop-up at Juan Manuel Gálvez International Airport in Roatán (gate D5–D6), and the Island Shop inside the Kimpton Grand Roatán Resort + Spa at West Bay Beach.' },
];
---

<section class="vd-section" style="background:#FBF7EF">
  <div class="wrap">
    <div class="head">
      <div class="vd-eyebrow" style="margin-bottom:16px">FAQ</div>
      <h2 class="vd-h2">Frequently Asked Questions</h2>
      <p>Common questions about sizing, shipping, returns and the brand.</p>
    </div>

    <div class="list" data-faq>
      {faqs.map((f, i) => (
        <div class="item" data-open={i === 0 ? 'true' : undefined}>
          <button type="button" class="q" data-faq-toggle aria-expanded={i === 0 ? 'true' : 'false'}>
            <span>{f.q}</span>
            <span class="circle" aria-hidden="true">
              <svg class="minus" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14"/></svg>
              <svg class="plus" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
            </span>
          </button>
          <div class="a">{f.a}</div>
        </div>
      ))}
      <div class="tail"></div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var root = document.querySelector('[data-faq]');
      if (!root) return;
      var items = root.querySelectorAll('.item');
      items.forEach(function (item) {
        var btn = item.querySelector('[data-faq-toggle]');
        btn.addEventListener('click', function () {
          var isOpen = item.hasAttribute('data-open');
          items.forEach(function (it) {
            it.removeAttribute('data-open');
            it.querySelector('[data-faq-toggle]').setAttribute('aria-expanded', 'false');
          });
          if (!isOpen) {
            item.setAttribute('data-open', 'true');
            btn.setAttribute('aria-expanded', 'true');
          }
        });
      });
    })();
  </script>
</section>

<style>
  .wrap { max-width: 820px; margin: 0 auto; padding: 0 clamp(20px, 4vw, 48px); }
  .head { text-align: center; margin-bottom: 44px; }
  .head p { margin: 16px 0 0; font: 400 16px/1.6 var(--font-sans); color: #54636A; }

  .item { border-top: 1px solid #E4DBCB; }
  .tail { border-top: 1px solid #E4DBCB; }

  .q {
    width: 100%; display: flex; align-items: center; justify-content: space-between;
    gap: 20px; background: none; border: 0; cursor: pointer; text-align: left;
    padding: 24px 4px; font-family: var(--font-sans);
  }
  .q > span:first-child { font: 500 18px/1.35 var(--font-sans); color: #0F2C36; }
  .circle {
    flex-shrink: 0; width: 30px; height: 30px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 50%; background: #F1E9DA; color: #0F2C36;
  }
  .minus { display: none; }
  .item[data-open] .minus { display: block; }
  .item[data-open] .plus { display: none; }

  .a {
    display: none;
    padding: 0 4px 26px; max-width: 660px;
    font: 400 15.5px/1.65 var(--font-sans); color: #54636A;
  }
  .item[data-open] .a { display: block; animation: faqIn .3s ease; }
  @keyframes faqIn { from { opacity: 0 } to { opacity: 1 } }
</style>
