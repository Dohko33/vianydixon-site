---
const faqs = [
  { q: 'How do I find my size?', a: '<p>Every product page shows our size chart with measurements in cm and inches. See our full size guide for detailed instructions.</p>' },
  { q: 'Where do you ship?', a: '<p>Worldwide from Honduras. Standard delivery to the US arrives in 5–8 business days. Inquire via WhatsApp for international rates.</p>' },
  { q: 'Is your swimwear UPF certified?', a: '<p>Yes — all our swim and rashguard products are independently tested and certified UPF 50+.</p>' },
  { q: 'Can I return or exchange?', a: '<p>Free returns within 30 days for unworn items with tags attached.</p>' },
  { q: 'Do you have a physical store?', a: '<p>Yes — visit our Island Outfitters pop-up at Juan Manuel Gálvez International Airport in Roatán, gate D5–D6, and the Island Shop inside the Kimpton Grand Roatán Resort + Spa at West Bay Beach.</p>' },
];
---

<section class="bg-(--color-sand) px-5 sm:px-8 py-14 lg:py-20">
  <div class="max-w-[900px] mx-auto">
    <p class="text-[11px] tracking-[0.12em] uppercase font-bold mb-3">FAQ</p>
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-medium tracking-[-0.025em] leading-[1.05] mb-3">Frequently Asked Questions</h2>
    <p class="text-(--color-muted) mb-10 max-w-2xl">Common questions about sizing, shipping, returns and the brand.</p>

    <div class="space-y-3">
      {faqs.map((f) => (
        <details class="bg-white border border-(--color-line) group">
          <summary class="px-5 py-5 cursor-pointer flex items-center justify-between gap-4 list-none">
            <span class="text-base sm:text-lg font-semibold">{f.q}</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0 transition-transform group-open:rotate-180">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </summary>
          <div class="px-5 pb-5 text-(--color-muted) text-[15px] leading-relaxed" set:html={f.a}></div>
        </details>
      ))}
    </div>
  </div>
</section>
