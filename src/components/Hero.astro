---
import { waLink } from '../data/site';
---

<section class="relative h-[72vh] sm:h-[80vh] min-h-[480px] overflow-hidden bg-black">
  <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover">
    <source src="/videos/hero-tropical.mp4" type="video/mp4" />
  </video>
  <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-transparent to-black/60"></div>

  <div class="relative h-full max-w-[1500px] mx-auto px-5 sm:px-8 flex flex-col justify-end pb-16 lg:pb-24">
    <p class="text-[11px] tracking-[0.18em] uppercase font-bold mb-4 text-white/85">New Arrivals · 2026</p>
    <h1 class="font-serif italic text-[56px] sm:text-[88px] lg:text-[120px] font-medium tracking-[-0.02em] leading-[0.95] text-white max-w-2xl mb-5">
      Feel As<br/>You Want.
    </h1>
    <p class="text-base sm:text-lg text-white/90 max-w-md mb-8 leading-relaxed">
      Island performance wear made for movement, sea and sun.
    </p>
    <div class="flex gap-3 flex-wrap">
      <a href="/collections/swim" class="btn btn-primary" style="background:white;color:#000;">Shop Swim</a>
      <a href={waLink()} target="_blank" rel="noopener" class="btn btn-ghost" style="border-color:white;color:white;">Inquire</a>
    </div>
  </div>
</section>
